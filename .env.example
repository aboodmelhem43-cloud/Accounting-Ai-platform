# قاعدة البيانات — PostgreSQL عبر Neon أو Supabase
DATABASE_URL="postgresql://user:password@host:5432/accounting_db?sslmode=require"

# NextAuth — يجب توليده بـ: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# مسار رفع الملفات (محلي في التطوير)
UPLOAD_DIR="public/uploads"

# Resend — إرسال البريد الإلكتروني
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@mohasabai.com"

# Lemon Squeezy — بوابة الدفع
LEMONSQUEEZY_API_KEY="eyJ0eXAiOiJKV1Qi..."
LEMONSQUEEZY_STORE_ID="12345"
LEMONSQUEEZY_WEBHOOK_SECRET="your-webhook-secret"
LEMONSQUEEZY_VARIANT_STARTER="111111"
LEMONSQUEEZY_VARIANT_PRO="222222"
LEMONSQUEEZY_VARIANT_BUSINESS="333333"

# URL العام للتطبيق (بدون trailing slash)

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// المنشأة التجارية — كل مستخدم ينتمي لمنشأة واحدة في المرحلة الأولى
model Business {
  id                  String    @id @default(cuid())
  name                String
  country             String    @default("EG")
  baseCurrency        String    @default("EGP")
  taxNumber           String?
  address             String?
  phone               String?
  onboardingCompleted Boolean   @default(false)
  plan                String    @default("FREE_TRIAL") // FREE_TRIAL | STARTER | PRO | BUSINESS
  trialEndsAt         DateTime?
  lsSubscriptionId    String?   @unique // Lemon Squeezy subscription ID
  lsCustomerId        String?   // Lemon Squeezy customer ID
  lsVariantId         String?   // active variant ID
  lsCurrentPeriodEnd  DateTime? // when current billing period ends
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  users          User[]
  accounts       Account[]
  journalEntries JournalEntry[]
  invoices       Invoice[]
  contacts       Contact[]
  bankAccounts   BankAccount[]
  bankStatements BankStatement[]
  chatMessages   ChatMessage[]
  invites        Invite[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  businessId String
  role       String   // "user" | "assistant"
  content    String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// المستخدم — مرتبط بمنشأة واحدة
model User {
  id           String   @id @default(cuid())
  businessId   String
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
}

enum UserRole {
  OWNER
  ACCOUNTANT
}

// دليل الحسابات — Chart of Accounts
model Account {
  id         String      @id @default(cuid())
  businessId String
  name       String
  nameAr     String?     // الاسم بالعربي
  type       AccountType
  code       String      // رمز الحساب مثل 1100
  isSystem   Boolean     @default(false) // حسابات النظام الافتراضية لا تُحذف
  createdAt  DateTime    @default(now())

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]

  @@unique([businessId, code])
}

enum AccountType {
  ASSET     // أصول
  LIABILITY // خصوم
  EQUITY    // حقوق ملكية
  REVENUE   // إيرادات
  EXPENSE   // مصروفات
}

// قيد اليومية
model JournalEntry {
  id          String            @id @default(cuid())
  businessId  String
  date        DateTime
  description String
  sourceType  JournalSourceType @default(MANUAL)
  createdById String
  createdAt   DateTime          @default(now())
  status      JournalEntryStatus @default(POSTED)

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creator  User          @relation(fields: [createdById], references: [id])
  lines    JournalLine[]
  invoice  Invoice?
}

enum JournalSourceType {
  MANUAL
  AI_INVOICE
}

// سطور القيد — لازم مجموع debit = مجموع credit لكل قيد
model JournalLine {
  id             String  @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal @default(0) @db.Decimal(15, 2)
  credit         Decimal @default(0) @db.Decimal(15, 2)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
}

// الفواتير المرفوعة
model Invoice {
  id              String        @id @default(cuid())
  businessId      String
  fileUrl         String
  fileType        String        // image/pdf
  extractedData   Json?         // البيانات المستخرجة بالذكاء الاصطناعي
  status          InvoiceStatus @default(PENDING_REVIEW)
  invoiceType     InvoiceType   @default(PURCHASE) // مشتريات أو مبيعات
  journalEntryId  String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])
}

enum InvoiceStatus {
  PENDING_REVIEW
  CONFIRMED
  REJECTED
}

enum InvoiceType {
  PURCHASE // فاتورة مشتريات
  SALES    // فاتورة مبيعات
}

model Contact {
  id          String      @id @default(cuid())
  businessId  String
  type        ContactType
  name        String
  email       String?
  phone       String?
  address     String?
  taxNumber   String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

enum ContactType {
  CUSTOMER
  VENDOR
}

model BankAccount {
  id             String   @id @default(cuid())
  businessId     String
  name           String
  bankName       String
  accountNumber  String?
  iban           String?
  currency       String   @default("EGP")
  openingBalance Decimal  @default(0) @db.Decimal(15, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  statements BankStatement[]
}

model BankStatement {
  id            String   @id @default(cuid())
  businessId    String
  bankAccountId String?
  fileName      String
  uploadedAt    DateTime @default(now())

  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount?      @relation(fields: [bankAccountId], references: [id])
  transactions BankTransaction[]
}

model BankTransaction {
  id              String   @id @default(cuid())
  statementId     String
  date            DateTime
  description     String
  amount          Decimal  @db.Decimal(15, 2)
  transactionType String
  balance         Decimal? @db.Decimal(15, 2)
  reference       String?
  matched         Boolean  @default(false)

  statement BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
}

enum JournalEntryStatus {
  DRAFT
  POSTED
}

// دعوات إضافة مستخدمين فرعيين
model Invite {
  id         String    @id @default(cuid())
  businessId String
  email      String
  role       UserRole  @default(ACCOUNTANT)
  token      String    @unique @default(cuid())
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([token])
}

// رموز التحقق بالبريد الإلكتروني
model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String   // hashed
  purpose   String   // "register" | "login"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, purpose])
}
